{
  "name": "backend",
  "version": "3.0.0",
  "description": "Library management API (Express + Mongoose)",
  "main": "server.js",
  "type": "commonjs",
  "scripts": {
    "start": "node dist/server.js",
    "dev": "nodemon --watch \"./\" --ext ts --exec \"ts-node server.ts\"",
    "build": "tsc -p tsconfig.json",
    "seed": "ts-node src/seed.ts",
    "seed:build": "npm run build && node dist/src/seed.js",
    "test": "echo \"No tests configured\""
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "mongoose": "^8.6.0",
    "morgan": "^1.10.0",
    "cors": "^2.8.5"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/morgan": "^1.9.10",
    "@types/node": "^25.9.1",
    "newman": "^6.2.2",
    "nodemon": "^3.1.14",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
